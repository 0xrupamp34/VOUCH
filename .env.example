# VOUCH Protocol - Environment Configuration

# Blockchain
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
USDC_ADDRESS=0x...

# Contract Addresses (Base Sepolia)
AGENT_REGISTRY_ADDRESS=0x...
REPUTATION_ENGINE_ADDRESS=0x...
TASK_ESCROW_ADDRESS=0x...
DISPUTE_MANAGER_ADDRESS=0x...

# Chainlink
CHAINLINK_ORACLE_ADDRESS=0x...
CHAINLINK_JOB_ID=...
CHAINLINK_SUBSCRIPTION_ID=0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vouch

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-secret-key-change-in-production
SIWE_DOMAIN=localhost
SIWE_STATEMENT=Sign in to VOUCH Protocol

# IPFS/Pinata
IPFS_GATEWAY=https://ipfs.io/ipfs/
PINATA_API_URL=https://api.pinata.cloud
PINATA_API_KEY=...
PINATA_API_SECRET=...

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...
SMTP_FROM=noreply@vouch.xyz

# Slack
SLACK_WEBHOOK_URL=...
SLACK_BOT_TOKEN=...

# WalletConnect
WALLETCONNECT_PROJECT_ID=your-project-id

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id

# Admin
ADMIN_WALLETS=0x...

# Webhooks
WEBHOOK_SECRET=your-webhook-secret

# Deployment
NODE_ENV=development
PORT=4000
